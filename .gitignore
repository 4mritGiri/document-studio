# --- Rust (studio-core) ---
# # Generated by Cargo
# Contains all compiled artifacts, build cache, and dependencies
**/target/
**/*.rs.bk
*.pdb

# Remove this macro-expansion file if you use cargo-expand
cargo-expand.rs


# --- Python (Tests / Future Django) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
.pytest_cache/
.uv/

# --- IDEs & OS ---
.vscode/
.idea/
.zed/
.DS_Store
Thumbs.db
Cargo.lock

# --- Environment Variables ---
.env
.env.local
*.pem

# --- Generated Files (Keep docs/examples, ignore root level test outputs) ---
/*.pdf
/*.html
notes/*
